# Supabase Configuration
# Get these from your Supabase project settings
REACT_APP_SUPABASE_URL=your_supabase_url_here
REACT_APP_SUPABASE_KEY=your_supabase_anon_key_here

# Admin User Configuration
REACT_APP_ADMIN_EMAIL=your_admin_email_here
REACT_APP_ADMIN_PASSWORD=your_admin_password_here
REACT_APP_ADMIN_NAME=your_admin_name_here

# Optional: For future EmailJS integration
REACT_APP_EMAILJS_SERVICE_ID=your_service_id
REACT_APP_EMAILJS_TEMPLATE_ID=your_template_id
REACT_APP_EMAILJS_USER_ID=your_user_id
